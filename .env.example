# Authentication (REQUIRED in production)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long

# Admin access (comma-separated Ethereum addresses)
ADMIN_ADDRESSES=0x1234567890123456789012345678901234567890

# Web3 (optional - WalletConnect project ID for wallet modal branding)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXXXX

# Early access notifications (optional - falls back to console.log if RESEND_API_KEY missing)
RESEND_API_KEY=
EARLY_ACCESS_NOTIFY_TO=pierre@hearstcorporation.io
EARLY_ACCESS_NOTIFY_FROM=Hearst AI <noreply@hearstcorporation.io>
